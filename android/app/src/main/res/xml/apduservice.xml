<?xml version="1.0" encoding="utf-8"?>
<!--
  HCE AID group. The default AID below is in the proprietary F0... range so it
  does not collide with real payment/transit AIDs. Real-world emulation targets
  register their AID at runtime via CardEmulation.registerAidsForService().
  requireDeviceUnlock=false lets the door reader work from the lock screen.
-->
<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/hce_service_desc"
    android:requireDeviceUnlock="false">
    <aid-group
        android:description="@string/hce_aid_group_desc"
        android:category="other">
        <aid-filter android:name="F0010203040506"/>
    </aid-group>
</host-apdu-service>
